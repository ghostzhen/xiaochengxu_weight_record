.page {
  min-height: 100vh;
  padding: 30rpx;
  background: #f6f8fc;
  box-sizing: border-box;
}

.topbar {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.back-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  color: #333;
}

.topbar-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #17336d;
}

.topbar-right {
  width: 88rpx;
}

.section {
  background: #fff;
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 32rpx;
  color: #102a5e;
  font-weight: 700;
}

.section-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7ea8;
  line-height: 1.5;
}

.btn {
  margin-top: 16rpx;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0;
}

.btn::after {
  border: none;
}

.btn-light {
  background: #eef5ff;
  color: #2e7dff;
}

.btn-primary {
  background: #3dc466;
  color: #fff;
}

.btn-danger {
  background: #ff4d4f;
  color: #fff;
}

.feedback-input {
  width: 100%;
  min-height: 160rpx;
  margin-top: 14rpx;
  border: 1rpx solid #e4e9f5;
  border-radius: 14rpx;
  padding: 18rpx;
  box-sizing: border-box;
  font-size: 26rpx;
}

.help-list {
  margin-top: 14rpx;
}

.help-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.help-index {
  width: 32rpx;
  font-size: 24rpx;
  color: #2e7dff;
}

.help-text {
  flex: 1;
  font-size: 24rpx;
  color: #304567;
  line-height: 1.6;
}

.danger-section {
  border: 1rpx solid rgba(255, 77, 79, 0.2);
}
