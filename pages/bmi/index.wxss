.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 32rpx 40rpx 60rpx;
  box-sizing: border-box;
}

.topbar {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 12rpx 0 20rpx;
}

.back {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  color: #333;
}

.topbar-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.topbar-right {
  width: 88rpx;
}

.card,
.result-card,
.table-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
}

.row + .row {
  border-top: 1rpx solid #eee;
}

.label-col {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.hint {
  font-size: 22rpx;
  color: #999;
}

.input {
  width: 260rpx;
  height: 72rpx;
  border: 1rpx solid #eee;
  border-radius: 14rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  background: #fafafa;
  text-align: right;
}

.result-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.result-row + .result-row {
  border-top: 1rpx solid #eee;
}

.result-label {
  font-size: 28rpx;
  color: #666;
}

.result-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #3DC466;
}

.result-badge {
  font-size: 26rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #fff;
}

.badge-thin {
  background: #2E7DFF;
}

.badge-normal {
  background: #3DC466;
}

.badge-over {
  background: #FF9F0A;
}

.badge-obese {
  background: #FF4D4F;
}

.badge-empty {
  background: #bbb;
}

.table-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 18rpx;
  display: block;
}

.table-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-top: 1rpx solid #eee;
}

.table-row:first-child {
  border-top: 0;
}

.th {
  font-size: 26rpx;
  color: #666;
  font-weight: 600;
}

.td {
  font-size: 26rpx;
  color: #666;
}
