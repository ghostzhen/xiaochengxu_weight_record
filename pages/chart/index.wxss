/**index.wxss**/
page {
  min-height: 100vh;
}
.scrollarea {
  width: 100%;
  padding-top: env(safe-area-inset-top);
  box-sizing: border-box;
}

.chart-page {
  width: 100%;
}

.card {
  width: 100%;
  padding: 32rpx;
  box-sizing: border-box;
}

.card__title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 20rpx;
}

.card__desc {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.55);
}

.chart-wrap {
  width: 100%;
  height: 440rpx;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.chart {
  width: 100%;
  height: 100%;
}

.chart-placeholder {
  background: #fff;
}

.compare-card {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.06);
}

.habit-card {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.06);
}

.habit-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.habit-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10rpx;
}

.habit-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #666;
  min-width: 0;
}

.habit-icon {
  font-size: 40rpx;
}

.recent-card {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.06);
}

.water-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.06);
}

.water-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.water-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.water-badge {
  font-size: 22rpx;
  color: #2e7dff;
  background: rgba(46, 125, 255, 0.12);
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
}

.water-progress-row {
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.water-progress-text {
  font-size: 24rpx;
  color: #333;
}

.water-streak {
  font-size: 22rpx;
  color: #3dc466;
}

.water-bar {
  margin-top: 10rpx;
  width: 100%;
  height: 16rpx;
  border-radius: 999rpx;
  background: #edf3ff;
  overflow: hidden;
}

.water-bar-inner {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #36cfc9 0%, #2e7dff 100%);
}

.water-quick-row {
  margin-top: 16rpx;
  display: flex;
  gap: 12rpx;
}

.water-quick-btn {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
  color: #2e7dff;
  background: #f3f8ff;
}

.water-quick-btn::after {
  border: none;
}

.water-manual-row {
  margin-top: 12rpx;
  display: flex;
  gap: 10rpx;
  align-items: center;
}

.water-manual-input {
  flex: 1;
  height: 68rpx;
  border: 1rpx solid #e7ebf3;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
}

.water-manual-btn {
  width: 132rpx;
  height: 68rpx;
  line-height: 68rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
  color: #fff;
  background: #2e7dff;
}

.water-manual-btn::after {
  border: none;
}

.water-stats-row {
  margin-top: 12rpx;
  display: flex;
  gap: 18rpx;
}

.water-stat {
  font-size: 23rpx;
  color: rgba(0, 0, 0, 0.55);
}

.trend-card {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.06);
}

.trend-block {
  margin-top: 12rpx;
}

.trend-label {
  font-size: 23rpx;
  color: rgba(0, 0, 0, 0.55);
}

.trend-bars {
  margin-top: 10rpx;
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  min-height: 90rpx;
}

.trend-bars-month {
  gap: 4rpx;
}

.trend-bar-item {
  flex: 1;
  height: 86rpx;
  display: flex;
  align-items: flex-end;
}

.trend-bar-month-item {
  min-width: 0;
}

.trend-bar-fill {
  width: 100%;
  border-radius: 6rpx 6rpx 0 0;
  background: linear-gradient(180deg, #67a6ff 0%, #2e7dff 100%);
}

.recent-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.recent-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  gap: 16rpx;
}

.recent-label {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.55);
}

.recent-value {
  font-size: 24rpx;
  color: #333;
  text-align: right;
  flex: 1;
}

.compare-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.compare-label {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.55);
}

.compare-value {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.55);
}

.delta-up {
  color: #e53935;
}

.delta-down {
  color: #3dc466;
}

.delta-flat {
  color: rgba(0, 0, 0, 0.55);
}

.overlay {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
}

.overlay-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
}

.overlay-panel {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 560rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  z-index: 10000;
}

.overlay-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.overlay-row {
  margin-bottom: 14rpx;
}

.overlay-label {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.overlay-picker {
  height: 72rpx;
  line-height: 72rpx;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 0 20rpx;
  color: #333;
  background: #fff;
}

.overlay-value {
  height: 72rpx;
  line-height: 72rpx;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 0 20rpx;
  color: #333;
  background: #f8f8f8;
}

.overlay-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.overlay-input {
  height: 72rpx;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.overlay-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.overlay-mini-btn {
  margin-top: 10rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #2e7dff;
  background: #f3f8ff;
}

.overlay-mini-btn::after {
  border: none;
}
