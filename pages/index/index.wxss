/* 体重记录首页 - 与 Pencil 设计一致 */
page {
  height: 100vh;
  background: #f5f5f5;
}

.page {
  height: 100%;
  display: flex;
  flex-direction: column;
  position: relative;
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

.scrollarea {
  flex: 1;
  height: 0;
}

/* ========== 日历区 ========== */
.calendar-section {
  background: #fff;
  padding: 32rpx 40rpx 40rpx;
  margin-bottom: 0;
}

.cal-header {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 16rpx;
}

.cal-month {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}

.cal-month-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #666;
  border-radius: 28rpx;
  background: #f3f3f3;
}

.cal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.week-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.week-cell {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

.day-row {
  display: flex;
  justify-content: space-between;
  height: 64rpx;
  align-items: center;
}

.day-cell {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333;
}

.day-cell--selected {
  background: #3DC466;
  color: #fff;
  border-radius: 50%;
  margin: 0 4rpx;
}

/* ========== 体重数据区 ========== */
.data-section {
  flex: 1;
  background: #fff;
  padding: 32rpx 40rpx 80rpx;
  padding-bottom: 140rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.checkin-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.checkin-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.checkin-title {
  font-size: 24rpx;
  color: #666;
}

.checkin-days {
  font-size: 30rpx;
  font-weight: 700;
  color: #111;
}

.checkin-hint {
  font-size: 22rpx;
  color: #999;
  text-align: right;
  max-width: 360rpx;
}

/* 目标进度 */
.goal-block {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eee;
}

.goal-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.goal-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.goal-set {
  font-size: 24rpx;
  color: #3DC466;
}

.goal-label {
  font-size: 26rpx;
  color: #666;
}

.goal-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #3DC466;
}

.progress-track {
  height: 12rpx;
  background: #eee;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: #3DC466;
  border-radius: 6rpx;
}

.goal-sub {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.smart-hint {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #3DC466;
}

.hint-icon {
  font-size: 22rpx;
}

/* 历史对比卡片 */
.history-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  margin: 20rpx 0;
  font-size: 24rpx;
  color: #666;
}

.selected-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  margin: 20rpx 0;
  font-size: 24rpx;
  color: #666;
}

/* 体围/体脂入口 */
.body-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  font-size: 26rpx;
  color: #3DC466;
}

.entry-arrow {
  font-size: 36rpx;
  color: #999;
}

/* 数据行 */
.data-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eee;
}

.data-row-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.data-label {
  font-size: 28rpx;
  color: #666;
}

.data-value-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.data-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #3DC466;
}

.data-unit {
  font-size: 28rpx;
  color: #666;
}

.unit-switch {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
}

.unit-opt {
  color: #999;
}

.unit-opt.active {
  color: #3DC466;
  font-weight: 600;
}

.unit-div {
  color: #ccc;
}

.status-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #3DC466;
}

.status-icon {
  font-size: 24rpx;
}



.remark-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #999;
}

.remark-ico {
  font-size: 22rpx;
}

.data-tag,
.data-date {
  font-size: 28rpx;
  color: #666;
}

.data-date {
  font-size: 24rpx;
}

.data-link {
  font-size: 24rpx;
  color: #666;
}

.fab-spacer {
  height: 40rpx;
}

/* 悬浮记录按钮 */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 180rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #3DC466;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.fab-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

/* 输入弹层 */
.overlay {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}
.overlay-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 0;
}
.overlay-panel {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 560rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.2);
  z-index: 1;
}
.overlay-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 16rpx;
}
.overlay-row {
  margin-bottom: 14rpx;
}
.overlay-label {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}
.overlay-picker {
  height: 72rpx;
  line-height: 72rpx;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 0 20rpx;
  color: #333;
  background: #fff;
}
.overlay-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.overlay-input {
  height: 72rpx;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 0 20rpx;
}
.overlay-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}
